                            >
                                <span className={activeTab === key ? 'text-pastel-ink' : 'text-pastel-text'}>
                                    {tabs[key].icon}
                                </span>
                                <span>{tabs[key].title}</span>
                            </button>
                        ))}
                    </div>
                    
                    {/* Área de Conteúdo da Aba com Slideshow */}
                    <div className="flex-1 bg-white custom-border p-6 md:p-8 relative overflow-hidden shadow-woodcut">
                        <div className="relative z-10 flex flex-col h-full">
                            
                            {/* Título da Seção */}
                            <div className="flex items-center gap-3 mb-6 border-b-2 border-pastel-ink pb-4 shrink-0">
                                <div className="p-2 bg-pastel-sand custom-border text-pastel-ink">
                                    {tabs[activeTab].icon}
                                </div>
                                <h3 className="text-2xl font-bold font-serif text-pastel-ink">{tabs[activeTab].title}</h3>
                            </div>

                            {/* Container Dividido: Texto e Slideshow */}
                            <div className="w-full flex-1 flex flex-col lg:flex-row gap-8">
                                {/* Lado Esquerdo: Texto da Aba */}
                                <div className="flex-1 flex flex-col justify-start">
                                    {tabs[activeTab].content}
                                </div>
                                
                                {/* Lado Direito: Slideshow Dinâmico por Aba */}
                                <div className="w-full lg:w-[50%] xl:w-[60%] shrink-0 flex flex-col min-h-[450px]">
                                    <Slideshow images={tabImages[activeTab]} />
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            );
        };

        // 3. Conteúdo Interativo: Como será avaliado?
        const ComoContent = () => {
            const [checkedItems, setCheckedItems] = useState([false, false, false]);
            
            const toggleItem = (index) => {
                const newItems = [...checkedItems];
                newItems[index] = !newItems[index];
                setCheckedItems(newItems);
            };

            const metricas = [
                { 
                    label: "1. Cartografias e Análise Espacial (Leitura Técnica)", 
                    subItems: [
                        { title: "Cartografia Temática", text: "Mapas focados em bacias hidrográficas (Rio Jequitinhonha), áreas de risco, escassez hídrica (semiárido) e proteção ambiental." },
                        { title: "Sistemas de Informação Geográfica (SIG)", text: "Uso de dados digitais para georreferenciar a infraestrutura de saneamento (poços tubulares, barragens, redes de água/esgoto e lixões)." },
                        { title: "Cartografia Social/Participativa", text: "Mapas construídos pelos moradores rurais (povoados e fazendas) para identificar fontes de água, áreas de seca e locais de descarte inadequado." }
                    ],
                    ref: "Produto C - Diagnóstico Técnico-Participativo / SanBas"
                },
                { 
                    label: "2. Pesquisas e Coleta de Dados (Leitura Técnica)", 
                    subItems: [
                        { title: "Pesquisas Socioeconômicas", text: "Levantamentos sobre o perfil demográfico e acesso a serviços básicos, essenciais para entender a exclusão histórica no município." },
                        { title: "Diagnóstico Rápido Participativo (DRP)", text: "Metodologia ágil e direta para coletar informações nas comunidades rurais (que compõem 16,9% da população de Novorizonte)." },
                        { title: "Auditoria de Infraestrutura in loco", text: "Levantamento técnico das condições físicas e operacionais dos sistemas de abastecimento e manejo de resíduos sólidos." }
                    ],
                    ref: "Metodologias do Projeto SanBas / IBGE"
                },
                { 
                    label: "3. Participação Popular e Consulta Social (Leitura Comunitária)", 
                    subItems: [
                        { title: "Audiências e Consultas Públicas", text: "Reuniões formais para apresentação, debate e validação do diagnóstico e dos prognósticos do PMSB junto à população." },
                        { title: "Oficinas de Setorização", text: "Dinâmicas em pequenos grupos (distritos e comunidades) para garantir que as demandas específicas das 26 fazendas sejam incorporadas ao plano." },
                        { title: "Comitês de Coordenação e Executivo", text: "Órgãos colegiados formados por representantes do poder público e sociedade civil para acompanhar e aprovar as etapas do PMSB." }
                    ],
                    ref: "Produtos A e B - Estratégias de Mobilização Social"
                }
            ];

            return (
                <div className="content-layer">
                    <div className="mb-6 p-5 bg-pastel-sand/50 custom-border border-l-4 border-l-pastel-peach shadow-woodcut-sm">
                        <p className="font-serif italic text-pastel-ink text-lg leading-relaxed">
                            "A combinação de leitura técnica (cartografias/pesquisas) com a leitura comunitária (participação popular) é a base de um diagnóstico urbanístico eficiente e democrático."
                        </p>
                    </div>

                    <div className="space-y-4">
                        {metricas.map((metrica, index) => (
                            <div 
                                key={index}
                                onClick={() => toggleItem(index)}
                                className={`group cursor-pointer flex items-start gap-4 p-5 custom-border transition-all duration-200 flex-col sm:flex-row
                                    ${checkedItems[index] ? 'bg-pastel-green/40 shadow-woodcut-sm' : 'bg-white hover:bg-pastel-sand hover:shadow-woodcut-sm'}`}
