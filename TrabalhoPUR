                            </div>
                            <div className="mt-6 pt-3 border-t-2 border-pastel-ink/20 text-xs text-pastel-ink/80 font-sans italic">
                                <strong>Referências:</strong> Produto Interno Bruto dos Municípios IBGE (2023); IDEB e Mortalidade Infantil - Cidades IBGE (2023); SOUZA, H. N. de (2024).
                            </div>
                        </div>
                    )
                }
            };

            return (
                <div className="flex flex-col md:flex-row gap-6 content-layer h-full">
                    {/* Menu de Abas */}
                    <div className="flex md:flex-col gap-3 overflow-x-auto pb-2 md:pb-0 md:w-1/4 lg:w-1/5 shrink-0 hide-scrollbar">
                        {Object.keys(tabs).map((key) => (
                            <button
                                key={key}
                                onClick={() => setActiveTab(key)}
                                className={`flex items-center gap-3 px-4 py-3 text-left transition-all whitespace-nowrap md:whitespace-normal font-sans font-bold custom-border
