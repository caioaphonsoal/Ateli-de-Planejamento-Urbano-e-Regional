<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apresentação Novorizonte - Estilo Xilogravura e Tons Pastéis</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Babel e React -->
    <script src="https://unpkg.com/react@18/umd/react.development.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        pastel: {
                            bg: '#FDFBF7',     /* Fundo principal areia claro */
                            peach: '#E8C3B3',  /* Pêssego pastel */
                            blue: '#B9D2D0',   /* Azul pastel */
                            green: '#CDE0C0',  /* Verde pastel */
                            sand: '#F2E8D3',   /* Areia */
                            ink: '#2B2624',    /* Tinta escura/Marrom */
                            text: '#4A4440',   /* Texto secundário */
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Lora', 'serif'],
                    },
                    boxShadow: {
                        'woodcut': '6px 6px 0px 0px rgba(43, 38, 36, 1)',
                        'woodcut-sm': '4px 4px 0px 0px rgba(43, 38, 36, 1)',
                    }
                }
            }
        }
    </script>

    <style>
        /* Textura base para lembrar papel */
        body {
            background-color: #FDFBF7;
            background-image: url('data:image/svg+xml;utf8,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)" opacity="0.03"/%3E%3C/svg%3E');
        }

        /* Estilos para as ilustrações de xilogravura espalhadas */
        .woodcut-bg {
            position: absolute;
            opacity: 0.15; /* Meio tom */
            pointer-events: none;
            z-index: 0;
            mix-blend-mode: multiply;
            filter: grayscale(100%) contrast(1.2);
        }

        .custom-border {
            border: 2px solid #2B2624;
        }

        /* Garantir que o conteúdo fique acima das imagens de fundo */
        .content-layer {
            position: relative;
            z-index: 10;
        }
        
        /* Ocultar barra de rolagem mas manter funcionalidade para um visual mais limpo */
        .hide-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .hide-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .hide-scrollbar::-webkit-scrollbar-thumb {
            background-color: rgba(43, 38, 36, 0.2);
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        // --- Ícones Inline SVG ---
        const IconTarget = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>;
        const IconMapPin = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>;
        const IconBookOpen = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>;
        const IconX = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>;
        const IconChevronDown = ({className}) => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="m6 9 6 6 6-6"/></svg>;
        const IconCheckCircle2 = ({className}) => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>;
        const IconChevronRight = ({className}) => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="m9 18 6-6-6-6"/></svg>;
        const IconHistory = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>;
        const IconLeaf = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>;
        const IconUsers = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>;
        const IconTrendingUp = () => <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>;

        // --- COMPONENTE SLIDESHOW ---
        const Slideshow = ({ images }) => {
            const [currentIndex, setCurrentIndex] = useState(0);

            // Reseta o slide para o primeiro sempre que as imagens mudarem (ao trocar de aba)
            useEffect(() => {
                setCurrentIndex(0);
            }, [images]);

            useEffect(() => {
                if (!images || images.length <= 1) return; // Não roda o timer se tiver apenas 1 foto
                const interval = setInterval(() => {
                    setCurrentIndex((prev) => (prev + 1) % images.length);
                }, 3500); // Troca a cada 3.5 segundos
                return () => clearInterval(interval);
            }, [images]);

            return (
                <div className="w-full h-full min-h-[300px] lg:min-h-full custom-border shadow-woodcut-sm bg-pastel-sand overflow-hidden relative group flex items-center justify-center">
                    {images.map((img, index) => (
                        <img
                            key={index}
                            src={img}
                            alt={`Imagem ${index + 1}`}
                            className={`absolute inset-0 w-full h-full object-contain p-4 transition-opacity duration-1000 ease-in-out ${index === currentIndex ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
                        />
                    ))}
                    {/* Indicadores - Só aparece se houver mais de uma imagem */}
                    {images.length > 1 && (
                        <div className="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-20">
                            {images.map((_, idx) => (
                                <button 
                                    key={idx} 
                                    onClick={() => setCurrentIndex(idx)}
                                    className={`w-2 h-2 rounded-full transition-all border border-pastel-ink/30 shadow-sm ${idx === currentIndex ? 'bg-pastel-ink w-5' : 'bg-pastel-ink/20 hover:bg-pastel-ink/50'}`} 
                                />
                            ))}
                        </div>
                    )}
                </div>
            );
        };


        // --- COMPONENTES GRÁFICOS (XILOGRAVURA STYLE) ---
        const RaceChart = () => {
            const data = [
                { label: 'Parda', val: 3111, bg: 'bg-pastel-peach' },
                { label: 'Branca', val: 1238, bg: 'bg-pastel-sand' },
                { label: 'Preta', val: 210, bg: 'bg-pastel-blue' },
                { label: 'Indígena', val: 10, bg: 'bg-pastel-green' },
                { label: 'Amarela', val: 2, bg: 'bg-white' },
            ];
            return (
                <div className="space-y-2 mt-4">
                    {data.map(d => (
                        <div key={d.label} className="flex items-center text-xs font-sans font-bold text-pastel-ink uppercase tracking-wider">
                            <span className="w-20 truncate">{d.label}</span>
                            <div className="flex-1 h-4 bg-white custom-border mx-2 overflow-hidden flex">
                                <div className={`h-full border-r-2 border-pastel-ink ${d.bg}`} style={{width: `${(d.val/4571)*100}%`}}></div>
                            </div>
                            <span className="w-10 text-right">{d.val}</span>
                        </div>
                    ))}
                </div>
            );
        };

        const PyramidChart = () => {
            const data = [
                { age: '60+', m: 18, f: 20 },
                { age: '40-59', m: 28, f: 30 },
                { age: '20-39', m: 34, f: 32 },
                { age: '0-19', m: 20, f: 18 },
            ];
            return (
                <div className="flex flex-col space-y-2 mt-4">
                    <div className="flex justify-between text-[10px] font-bold uppercase text-pastel-ink mb-1">
                        <span>Homens</span>
                        <span>Mulheres</span>
                    </div>
                    {data.map(d => (
                        <div key={d.age} className="flex items-center justify-center text-xs font-sans font-bold text-pastel-ink">
                            <div className="flex-1 flex justify-end">
                                <div className="h-4 bg-pastel-blue custom-border border-r-0" style={{width: `${d.m}%`}}></div>
                            </div>
                            <span className="w-14 text-center text-[10px] bg-white custom-border py-0.5 z-10">{d.age}</span>
                            <div className="flex-1 flex justify-start">
                                <div className="h-4 bg-pastel-peach custom-border border-l-0" style={{width: `${d.f}%`}}></div>
                            </div>
                        </div>
                    ))}
                </div>
            );
        };

        const StatCard = ({ title, value, subtitle, data, color, maxVal }) => {
            const max = maxVal || Math.max(...data);
            const width = 100;
            const height = 25;
            const points = data.map((d, i) => `${(i / (data.length - 1)) * width},${height - (d / max) * height}`).join(' ');

            return (
                <div className="p-4 border-2 border-pastel-ink bg-white shadow-woodcut-sm flex flex-col justify-between">
                    <h4 className="font-serif font-bold text-pastel-ink text-sm leading-tight mb-2">{title}</h4>
                    <div className="text-3xl font-bold font-serif text-pastel-ink mb-2">{value}</div>
                    <div className="mt-auto">
                        <svg viewBox={`-3 -3 ${width+6} ${height+6}`} className="w-full h-8 overflow-visible">
                            <polyline fill="none" stroke={color} strokeWidth="2.5" points={points} strokeLinejoin="round" strokeLinecap="round" />
                            <circle cx={(data.length - 1) / (data.length - 1) * width} cy={height - (data[data.length-1] / max) * height} r="3" fill={color} />
                        </svg>
                        <p className="text-[9px] uppercase font-bold text-pastel-text mt-3 text-center tracking-wider">{subtitle}</p>
                    </div>
                </div>
            );
        };

        // --- COMPONENTES DE CONTEÚDO DOS MODAIS ---

        // 1. Conteúdo Interativo: Qual o problema?
        const ProblemaContent = () => {
            const [activeStep, setActiveStep] = useState(0);
            
            const steps = [
                { 
                    title: "Déficits nos Eixos do Saneamento", 
                    desc: "A ausência ou ineficiência na prestação de serviços adequados nos quatro eixos estruturais: abastecimento de água potável, esgotamento sanitário, limpeza urbana e manejo de resíduos sólidos, além da drenagem de águas pluviais. O cenário exige levantamentos para dimensionar a demanda de infraestrutura, especialmente nas áreas rurais e povoados.",
                    ref: "Produto D - Prognóstico do Saneamento Básico; Resumo Executivo - Produtos A a F."
                },
                { 
                    title: "Exclusão Histórica e Universalização", 
                    desc: "A necessidade imperativa de garantir que o saneamento alcance a todos, priorizando populações e grupos historicamente excluídos do acesso ao básico e necessário para uma vida digna, visando a universalização dos serviços no município.",
                    ref: "Resumo Executivo - Produtos A a F (Apresentação do Projeto SanBas, p. 2)."
                },
                { 
                    title: "Sustentabilidade e Gestão de Riscos", 
                    desc: "A formulação de programas e projetos é dificultada pela vulnerabilidade ambiental (como os longos períodos de seca do semiárido) e falhas de infraestrutura. Há o desafio de estruturar metas de curto, médio e longo prazo que englobem educação em saúde, convivência com o semiárido e a recuperação de mananciais.",
                    ref: "Produto E - Programas, Projetos e Ações; Produto D - Prognóstico do Saneamento Básico."
                }
            ];

            return (
                <div className="space-y-4 content-layer">
                    {steps.map((step, index) => (
                        <div 
                            key={index} 
                            className={`custom-border bg-white transition-all duration-300 overflow-hidden ${activeStep === index ? 'shadow-woodcut' : 'hover:shadow-woodcut-sm'}`}
                        >
                            <button 
                                className="w-full px-5 py-4 text-left flex justify-between items-center bg-transparent cursor-pointer"
                                onClick={() => setActiveStep(activeStep === index ? -1 : index)}
                            >
                                <span className="font-bold text-pastel-ink font-serif text-xl flex items-center gap-4">
                                    <span className={`flex items-center justify-center w-8 h-8 font-sans text-sm custom-border ${activeStep === index ? 'bg-pastel-peach text-pastel-ink' : 'bg-pastel-sand text-pastel-text'}`}>
                                        {index + 1}
                                    </span>
                                    {step.title}
                                </span>
                                <div className={`transition-transform duration-300 ${activeStep === index ? 'rotate-180 text-pastel-peach' : 'text-pastel-ink'}`}>
                                    <IconChevronDown className="w-6 h-6" />
                                </div>
                            </button>
                            <div className={`px-5 transition-all duration-300 ease-in-out border-t-2 border-transparent flex flex-col justify-between ${activeStep === index ? 'py-5 bg-pastel-sand/30 border-pastel-ink max-h-64 opacity-100' : 'max-h-0 py-0 opacity-0'}`}>
                                <p className="text-pastel-text pl-12 font-sans mb-4">{step.desc}</p>
                                <p className="text-[11px] text-pastel-ink/70 italic pl-12 font-sans border-t border-pastel-ink/10 pt-2">
                                    <strong>Referência:</strong> {step.ref}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            );
        };

        // 2. Conteúdo Interativo: Onde será avaliado? (Abas/Tabs + Slideshow)
        const OndeContent = () => {
            const [activeTab, setActiveTab] = useState('historia');
            
            // Dicionário separando as imagens específicas para cada aba
            // Você pode adicionar mais links dividindo por vírgulas dentro das aspas!
            const tabImages = {
                historia: [
                    "https://i.postimg.cc/JhWqTh7r/IMG-20250819-WA0013.jpg",
                    "https://i.postimg.cc/TPX9kP2x/IMG-20250809-151736639.jpg"
                ],
                geografia: [
                    "https://i.postimg.cc/s2Rcn2fR/IMG-20180421-103542037.jpg",
                    "https://i.postimg.cc/8CVHyCpY/IMG-20260113-WA0006.jpg"
                ],
                demografia: [
                    "https://i.postimg.cc/jjrX8jx9/IMG-20250819-WA0014.jpg"
                ],
                socioeconomico: [
                    "https://i.postimg.cc/fbhKHbz1/IMG-20260113-WA0008.jpg"
                ]
            };

            const tabs = {
                historia: {
                    icon: <IconHistory />,
                    title: "História e Ocupação",
                    content: (
                        <div className="space-y-4 flex flex-col h-full">
                            <div className="flex-1 space-y-4 font-sans text-pastel-text">
                                <p>A ocupação da região remonta ao século XVI com a expedição de Francisco Bruza de Spinosa (1553). Historicamente ligada a Salinas, a formação atual da cidade deve-se muito ao fazendeiro João Bernardino de Souza (João Davilino), proprietário da Fazenda Córrego da Xícara no antigo povoado de Indaiá.</p>
                                <p>Homem popular e trabalhador, João Bernardino atuou como Inspetor de Quarteirão e Inspetor da Escola Municipal. Em 1953, mobilizou a comunidade e conseguiu a doação de terras pelas famílias Almeida e Ferreira em uma chapada chamada "Novo Indaiá". O objetivo era construir uma praça e uma igreja dedicada a Nossa Senhora da Conceição, obra erguida em mutirão pelas famílias locais.</p>
                                <p>Em 06 de outubro de 1953, o então prefeito de Salinas, Dr. Costa, ao visitar o Novo Indaiá, admirou a vista da chapada e declarou a João Bernardino: <em>"isto aqui é muito bonito, é um horizonte"</em>. A inspiração gerou o nome "Novorizonte", que foi prontamente aceito por todos.</p>
                                <p>A localidade foi elevada à categoria de município e distrito (desmembrado de Salinas) pela Lei Estadual nº 12.030, em 21 de dezembro de 1995, sendo o distrito sede instalado oficialmente em 1º de janeiro de 1997.</p>
                            </div>
                            <div className="mt-6 pt-3 border-t-2 border-pastel-ink/20 text-xs text-pastel-ink/80 font-sans italic">
                                <strong>Referências:</strong> IBGE (História e Formação Administrativa, 2024); Francisco, Ederico. Raízes do Passado; SOUZA, Henrique Neyffer de (A cada dia, um novo horizonte, 2024).
                            </div>
                        </div>
                    )
                },
                geografia: {
                    icon: <IconLeaf />,
                    title: "Geografia e Meio Ambiente",
                    content: (
                        <div className="space-y-4 flex flex-col h-full">
                            <div className="flex-1 font-sans text-pastel-text">
                                <p>Novorizonte é um município localizado em uma região de planalto, situado em área de transição entre o Cerrado e a Mata Atlântica. Pertence à região do semiárido brasileiro, o que torna a dinâmica climática (incluindo períodos de seca) e a infraestrutura hídrica (barragens) desafios cruciais. É reconhecido também pela produção de inúmeras cachaças.</p>
                            </div>
                            <div className="mt-6 pt-3 border-t-2 border-pastel-ink/20 text-xs text-pastel-ink/80 font-sans italic">
                                <strong>Referências:</strong> SOUZA, Henrique Neyffer de. (2024); Dados do Sistema Nacional de Unidades de Conservação (SNUC).
                            </div>
                        </div>
                    )
                },
                demografia: {
                    icon: <IconUsers />,
                    title: "Perfil Demográfico",
                    content: (
                        <div className="space-y-4 flex flex-col h-full">
                            <div className="flex-1 space-y-4">
                                <div className="flex flex-wrap gap-3 mb-4">
                                    <span className="px-3 py-1 bg-pastel-sand custom-border text-xs font-bold text-pastel-ink uppercase">Gentílico: Novorizontino</span>
                                    <span className="px-3 py-1 bg-pastel-sand custom-border text-xs font-bold text-pastel-ink uppercase">Aniversário: 21 de Dezembro</span>
                                </div>
                                <p className="text-pastel-text font-sans">
                                    Segundo o <strong>Censo IBGE 2022</strong>, o município conta com uma população de <strong>4.571 habitantes</strong> e uma densidade demográfica de <strong>16,83 hab./km²</strong>. Historicamente, mantém-se o perfil de forte presença na área urbana (cerca de 83,1%), enquanto 16,9% residem na área rural. A idade mediana é de 37 anos.
                                </p>
                                
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                                    <div className="p-5 border-2 border-pastel-ink bg-pastel-bg shadow-woodcut-sm">
                                        <h4 className="font-serif font-bold text-pastel-ink mb-2 border-b-2 border-pastel-ink pb-2">Cor ou Raça (2022)</h4>
                                        <RaceChart />
                                    </div>
                                    <div className="p-5 border-2 border-pastel-ink bg-pastel-bg shadow-woodcut-sm">
                                        <h4 className="font-serif font-bold text-pastel-ink mb-2 border-b-2 border-pastel-ink pb-2">Pirâmide Etária (2022)</h4>
                                        <PyramidChart />
                                    </div>
                                </div>
                            </div>
                            <div className="mt-6 pt-3 border-t-2 border-pastel-ink/20 text-xs text-pastel-ink/80 font-sans italic">
                                <strong>Referências:</strong> IBGE (Censo Demográfico 2022); Panorama IBGE Cidades (2024).
                            </div>
                        </div>
                    )
                },
                socioeconomico: {
                    icon: <IconTrendingUp />,
                    title: "Contexto Socioeconômico",
                    content: (
                        <div className="space-y-6 flex flex-col h-full">
                            <div className="flex-1 space-y-6">
                                <p className="text-pastel-text font-sans">
                                    Localizado na mesorregião do Norte de Minas (microrregião de Salinas) e pertencente à Bacia Hidrográfica do Rio Jequitinhonha. O território é formado pelos distritos Sede e Campo Verde de Minas, pelos povoados de Baixa da Cambaúba, Baixa do Bitu, Indaiá e São João do Pequi, pela comunidade de Alto São João e por 26 fazendas na área rural. Destaca-se a presença de povos tradicionais geraizeiros.
                                </p>

                                <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
                                    <StatCard 
                                        title="PIB per Capita" 
                                        value="R$ 20.256" 
                                        subtitle="Crescimento (2012-2023)" 
                                        data={[5, 6, 7, 8, 10, 11, 13, 19, 20.2]} 
                                        color="#2B2624" 
                                    />
                                    <StatCard 
                                        title="Mortalidade Infantil" 
                                        value="0" 
                                        subtitle="Óbitos/mil nv (2008-2023)" 
                                        data={[10, 14, 14, 44, 28, 20, 32, 20, 14, 18, 21, 20, 0]} 
                                        color="#2B2624" 
                                        maxVal={50}
                                    />
                                    <StatCard 
                                        title="IDEB (Anos Finais)" 
                                        value="4,6" 
                                        subtitle="Rede Pública (2005-2023)" 
                                        data={[2, 3, 4, 4, 4, 4, 4, 4, 5, 4.6]} 
                                        color="#2B2624" 
                                        maxVal={6}
                                    />
