                                <IconX />
                            </button>
                        </div>
                        
                        {/* Corpo do Modal */}
                        <div className="p-8 overflow-y-auto hide-scrollbar flex-1 relative z-10">
                            {children}
                        </div>
                    </div>
                </div>
            );
        };

        // Main App Component
        const App = () => {
            const [activeModal, setActiveModal] = useState(null);

            const cards = [
                {
                    id: 'problema',
                    title: 'Qual o problema?',
                    icon: IconTarget,
                    tag: 'Justificativa',
                    bgClass: 'bg-pastel-peach',
                    maxWidth: 'max-w-4xl', // Padrão
                    content: <ProblemaContent />
                },
                {
                    id: 'onde',
                    title: 'Onde será avaliado?',
                    icon: IconMapPin,
                    tag: 'Território',
                    bgClass: 'bg-pastel-blue',
                    maxWidth: 'max-w-[95vw] 2xl:max-w-[1600px]', // <--- Janela Extra Larga (8xl) para super destaque nas imagens
                    content: <OndeContent />
                },
                {
                    id: 'como',
                    title: 'Como será avaliado?',
                    icon: IconBookOpen,
                    tag: 'Metodologia',
                    bgClass: 'bg-pastel-green',
                    maxWidth: 'max-w-4xl', // Padrão
                    content: <ComoContent />
                }
            ];

            return (
                <div className="min-h-screen relative overflow-hidden">
                    
                    {/* Ilustrações Xilogravura de Fundo (Espalhadas) */}
                    <img src="https://i.postimg.cc/Kvn0SL1s/image.png" alt="Xilogravura Sertão 1" className="woodcut-bg top-5 -left-16 w-[350px]" />
                    <img src="https://i.postimg.cc/GpSQJxfp/image.png" alt="Xilogravura Sertão 2" className="woodcut-bg bottom-10 -right-24 w-[450px]" />
                    <img src="https://i.postimg.cc/xCw3BTnQ/image.png" alt="Xilogravura Sertão 3" className="woodcut-bg top-1/3 -right-12 w-[280px]" />
                    <img src="https://i.postimg.cc/fTjfgNFT/image.png" alt="Xilogravura Sertão 4" className="woodcut-bg bottom-1/4 -left-10 w-[320px]" />
                    <img src="https://i.postimg.cc/qv1X4G4D/image.png" alt="Xilogravura Sertão 5" className="woodcut-bg top-16 left-1/3 w-[200px]" />
                    <img src="https://i.postimg.cc/q7gcRC7R/image.png" alt="Xilogravura Sertão 6" className="woodcut-bg bottom-16 right-1/3 w-[250px]" />

                    {/* Header Institucional */}
                    <header className="border-b-2 border-pastel-ink bg-pastel-bg sticky top-0 z-30 content-layer">
                        <div className="max-w-6xl mx-auto px-6 py-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                            <div className="flex flex-col">
                                <div className="font-serif font-bold text-lg text-pastel-ink tracking-wide uppercase">
                                    Universidade Federal da Bahia
                                </div>
                                <div className="font-sans text-sm font-bold text-pastel-ink/80">
                                    ARQC10 - ATELIÊ DE FUNDAMENTAÇÃO DE PLANEJAMENTO URBANO E REGIONAL
                                </div>
                                <div className="font-sans text-xs text-pastel-text mt-1">
                                    Discente: Caio Aphonso Almeida &nbsp;&bull;&nbsp; Docente: Aline Barroso
                                </div>
                            </div>
                            <div className="font-sans text-sm font-bold bg-pastel-sand px-4 py-1 custom-border text-pastel-ink uppercase shrink-0">
                                Parte 1
                            </div>
                        </div>
                    </header>

                    <main className="max-w-6xl mx-auto px-6 py-12 content-layer relative">
                        
                        {/* Título e Subtítulo Principal */}
                        <div className="mb-16 flex flex-col items-center text-center gap-6 mx-auto">
                            <h1 className="text-4xl md:text-5xl font-bold font-serif text-pastel-ink leading-tight max-w-5xl">
                                Retratos do Saneamento Básico em Novorizonte - MG: <br className="hidden md:block"/>
                                <span className="text-3xl md:text-4xl text-pastel-ink/80 mt-2 block">Diagnóstico, Desafios e Caminhos para a Universalização</span>
                            </h1>
                            
                            <div className="border-t-4 border-pastel-peach px-6 md:px-10 py-6 max-w-4xl bg-white/60 custom-border shadow-woodcut-sm">
                                <p className="text-lg font-sans text-pastel-text leading-relaxed">
                                    Trabalho desenvolvido no escopo da disciplina <strong>ARQC10 - Ateliê de Fundamentação de Planejamento Urbano e Regional</strong>. 
                                    O objetivo deste material é investigar a realidade socioespacial e hídrica do município para desenvolver uma síntese interativa do diagnóstico técnico-participativo, servindo como base para a compreensão, estruturação e avaliação do Plano Municipal de Saneamento Básico (PMSB).
                                </p>
                            </div>
                        </div>

                        {/* Grid de Cards Interativos */}
                        <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
                            {cards.map((card) => {
                                const Icon = card.icon;
                                return (
                                    <div 
                                        key={card.id}
                                        onClick={() => setActiveModal(card.id)}
                                        className="group bg-white custom-border shadow-woodcut hover:translate-y-1 hover:shadow-woodcut-sm transition-all duration-200 cursor-pointer flex flex-col"
                                    >
                                        {/* Header Colorido do Card */}
                                        <div className={`p-4 border-b-2 border-pastel-ink flex justify-between items-center ${card.bgClass}`}>
                                            <span className="text-xs font-bold font-sans uppercase tracking-wider text-pastel-ink bg-white/50 px-2 py-1 custom-border">
                                                {card.tag}
                                            </span>
                                            <div className="bg-white p-2 custom-border text-pastel-ink">
                                                <Icon />
                                            </div>
                                        </div>
                                        
                                        <div className="p-8 flex-1 flex flex-col bg-pastel-bg">
                                            <h3 className="text-3xl font-bold font-serif mb-8 text-pastel-ink group-hover:underline decoration-2 underline-offset-4">
                                                {card.title}
                                            </h3>

                                            <div className="mt-auto inline-flex items-center gap-2 font-bold font-sans text-pastel-ink group-hover:gap-3 transition-all">
                                                <IconChevronRight className="w-5 h-5" />
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </main>

                    {/* Renderizar Modais */}
                    {cards.map(card => (
                        <Modal
                            key={`modal-${card.id}`}
                            isOpen={activeModal === card.id}
                            onClose={() => setActiveModal(null)}
                            title={card.title}
                            icon={card.icon}
                            bgClass={card.bgClass}
                            maxWidth={card.maxWidth}
                        >
                            {card.content}
                        </Modal>
                    ))}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
